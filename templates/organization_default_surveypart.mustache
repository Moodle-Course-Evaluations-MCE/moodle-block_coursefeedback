{{!
    @template block_coursefeedback/organization_default_surveypart

    This template renders the editing default surveyparts for an organization.

    Example context (json):
    {
       "formurl":"http:\/\/localhost\/moodle405\/blocks\/coursefeedback\/organization_default_surveypart.php?id=1",
       "sesskey":"Sn5pUMAzy8",
       "returnurl":"http:\/\/localhost\/moodle405\/blocks\/coursefeedback\/organization.php?id=1",
       "default_surveyparts":[
          {
             "id":1,
             "name":"Survey #1"
          },
          {
             "id":2,
             "name":"Survey #2",
             "selected":true
          }
       ],
       "eventtypes":[
          {
             "id":1,
             "name":"Vorlesung",
             "surveyparts":[
                {
                   "id":1,
                   "name":"Survey #1",
                   "selected":true
                },
                {
                   "id":2,
                   "name":"Survey #2"
                }
             ]
          },
          {
             "id":2,
             "name":"\u00dcbung",
             "surveyparts":[
                {
                   "id":1,
                   "name":"Survey #1"
                },
                {
                   "id":2,
                   "name":"Survey #2"
                }
             ]
          }
       ]
    }

}}

<form action="{{{formurl}}}" method="post" id="block_coursefeedback-default_surveypart_form">

    <div class="row align-items-center  my-3">
        <div class="col col-auto">
                {{#str}}default_surveypart_for_courses_without_eventtype, block_coursefeedback{{/str}}
        </div>
        <div class="col col-auto">
            <select class="form-control" name="surveypart-default">
                <option value="">-</option>
                {{#default_surveyparts}}
                    <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                {{/default_surveyparts}}
            </select>
        </div>
    </div>

    <table class="table table-striped table-hover generaltable">
        <thead>
            <tr>
                <th>{{#str}}eventtype, block_coursefeedback{{/str}}</th>
                <th>{{#str}}surveypart, block_coursefeedback{{/str}}</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {{#eventtypes}}
            {{>block_coursefeedback/organization_default_surveypart_row}}
        {{/eventtypes}}
        <tr class="add_eventtype_row">
            <td colspan="3">
                <div class="btn btn-link add_eventtype_btn">
                    {{#pix}}t/add{{/pix}} {{#str}}add_eventtype, block_coursefeedback{{/str}}
                </div>
            </td>
        </tr>
        </tbody>
    </table>
    <input type="hidden" name="sesskey" value="{{sesskey}}">
    <input type="hidden" name="added" value="">
    <input type="hidden" name="removed" value="">
    <input type="submit" name="submit" value="{{#str}}save{{/str}}" class="btn btn-primary">
    <a href="{{{returnurl}}}" class="btn btn-secondary">{{#str}}cancel{{/str}}</a>
</form>