\"optiontext\":\"Maybe\",\"optionid\":\"3\"}]},{\"type_scalequestion\":true,\"type\":\"scalequestion\",\"surveyitemid\":2,\"questiontext\":\"<p>Wie gut war's?<\\\/p>\",\"max_pole\":\"Sehr gut\",\"min_pole\":\"Sehr schlecht\",\"has_na_option\":true,\"na_option\":\"I forgor\",\"optionamount\":5,\"options\":[{\"id\":1,\"text\":\"Sehr schlecht\"},{\"id\":2,\"text\":null},{\"id\":3,\"text\":null},{\"id\":4,\"text\":null},{\"id\":5,\"text\":\"Sehr gut\"}],\"show_scale\":true},{\"type_text\":true,\"type\":\"text\",\"surveyitemid\":3,\"questiontext\":\"<p>M\\u00f6chtest du uns noch etwas mitteilen?<\\\/p>\"}],\"spe_id\":4}],\"default_slots\":{\"4\":4},\"courseid\":2}",
