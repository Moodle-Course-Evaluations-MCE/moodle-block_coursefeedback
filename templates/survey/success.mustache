{{!
    @template block_coursefeedback/survey/success

    This template renders the notification message to show a survey.

    Example context (json):

}}
<div class="alert alert-info alert-dismissible alert-block fade in" role="alert">
    {{#str}} survey_finished_thanks, block_coursefeedback {{/str}}
    <button type="button" class="btn-close" data-bs-dismiss="alert">
        <span class="visually-hidden">{{#str}}dismissnotification, core{{/str}}</span>
    </button>
</div>