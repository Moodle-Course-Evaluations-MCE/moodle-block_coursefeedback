{{!
    @template block_coursefeedback/survey/success

    The "thank you" notification that replaces the survey after submission.

    Example context (json):
    {}
}}
<div class="alert alert-success alert-dismissible alert-block fade in block_coursefeedback-survey-success" role="alert">
    {{#str}} survey_finished_thanks, block_coursefeedback {{/str}}
    <button type="button" class="close" data-dismiss="alert" data-bs-dismiss="alert"
            aria-label="{{#str}}dismissnotification, core{{/str}}">
        <span aria-hidden="true">&times;</span>
    </button>
</div>