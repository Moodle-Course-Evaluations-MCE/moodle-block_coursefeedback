{{!
    @template block_coursefeedback/show_survey

    This template renders the notification message to show a survey.

    Example context (json):
    {
  "questions": [
    {
      "type_singlechoice": true,
      "type": "singlechoice",
      "surveyitemid": 1,
      "questiontext": "<p>Im Rahmen welches Studiengangs besuchen Sie die Lehrveranstaltung?<\/p>",
      "options": [
        {
          "optiontext": "Bachelor",
          "optionid": "1"
        },
        {
          "optiontext": "Master",
          "optionid": "2"
        }
      ]
    },
    {
      "type_singlechoice": true,
      "type": "singlechoice",
      "surveyitemid": 2,
      "questiontext": "<p>In welchem Fachsemester studieren Sie?<\/p>",
      "options": [
        {
          "optiontext": "1",
          "optionid": "3"
        },
        {
          "optiontext": "2",
          "optionid": "4"
        },
        {
          "optiontext": "3",
          "optionid": "5"
        },
        {
          "optiontext": "4",
          "optionid": "6"
        },
        {
          "optiontext": "5",
          "optionid": "7"
        },
        {
          "optiontext": "6",
          "optionid": "8"
        },
        {
          "optiontext": "7",
          "optionid": "9"
        },
        {
          "optiontext": "8",
          "optionid": "10"
        },
        {
          "optiontext": "9",
          "optionid": "11"
        },
        {
          "optiontext": "10",
          "optionid": "12"
        },
        {
          "optiontext": "&gt;10",
          "optionid": "13"
        }
      ]
    }
  ],
  "amount_pages": 4
}

}}
<div class="alert alert-info p-4 block_coursefeedback-survey" id="block_coursefeedback-survey-root"
     style='--current-page: 1; --current-page-text: "1"; --amount-pages: {{amount_pages}}'>
    <div id="block_coursefeedback-survey-content">
        {{> block_coursefeedback/survey_questions }}
    </div>
    <div class="d-flex mb-3 justify-content-between">
        <button class="btn btn-secondary button-back" disabled>
            {{#str}}back{{/str}}
        </button>
        <button class="btn btn-primary button-next">
            {{#str}}next{{/str}}
        </button>
    </div>
    <div class="progress mb-3" role="progressbar" aria-hidden="true">
        <div class="progress-bar" style="width: calc(100% * (var(--current-page) - 1) / var(--amount-pages))"></div>
    </div>
    <div class="d-flex justify-content-around">
        <span>{{#str}} page {{/str}} <span class="current-page"></span> / {{amount_pages}}</span>
    </div>
</div>
