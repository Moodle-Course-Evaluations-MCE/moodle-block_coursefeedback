{{!
    @template block_coursefeedback/surveyitems/base

    Template purpose and description.

    Example context (json):
    {
      "type": "text",
      "surveyitemid": 5,
      "questiontext": "<p>Was hat Ihnen an der Veranstaltung gefallen? Was sollte beibehalten werden?<\/p>",
      "required": true
    }
}}

<form class="block_coursefeedback-surveyitem block_coursefeedback-{{type}} layout-{{$layout}}2-rows{{/layout}} {{$extra_classes}}{{/extra_classes}}"
      data-surveyitemid="{{surveyitemid}}">
    <div class="question-area">
        {{$question_area_content}}
            <span class="coursefeedback-questiontext">{{{ questiontext }}}</span>
            {{#required}}
                <span class="text-danger" title="{{#str}}required{{/str}}" aria-hidden="true">{{#pix}}req{{/pix}}</span>
            {{/required}}
        {{/question_area_content}}
    </div>
    {{$answer_area}}
        <div class="answer-area">
            {{$answer_area_content}}{{/answer_area_content}}
        </div>
    {{/answer_area}}
</form>
