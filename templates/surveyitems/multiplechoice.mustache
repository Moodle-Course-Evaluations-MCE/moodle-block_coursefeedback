{{!
    @template block_coursefeedback/surveyitems/multiplechoice

    This template renders the display of a multiplechoice question.

    Example context (json):
    {
    }

}}
{{{ questiontext }}}
<div class="mt-2 ms-3">
    {{# options }}
        <div class="form-check mt-1">
            <input class="form-check-input" type="checkbox" value="" id="block_coursefeedback-surveyitem-{{surveyitemid}}-{{optionid}}">
            <label class="form-check-label" for="block_coursefeedback-surveyitem-{{surveyitemid}}-{{optionid}}">
                {{{optiontext}}}
            </label>
        </div>
    {{/ options }}
</div>
