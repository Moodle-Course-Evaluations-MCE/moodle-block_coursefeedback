{{!
    @template block_coursefeedback/surveyitems/singlechoice

    This template renders the display of a singlechoice question.

    Example context (json):
    {
      "type_singlechoice": true,
      "type": "singlechoice",
      "surveyitemid": 2,
      "questiontext": "<p>In welchem Fachsemester studieren Sie?<\/p>",
      "required": false,
      "options": [
        {
          "optiontext": "1",
          "optionid": "3"
        },
        {
          "optiontext": "2",
          "optionid": "4"
        },
        {
          "optiontext": "3",
          "optionid": "5"
        },
        {
          "optiontext": "4",
          "optionid": "6"
        },
        {
          "optiontext": "5",
          "optionid": "7"
        },
        {
          "optiontext": "6",
          "optionid": "8"
        },
        {
          "optiontext": "7",
          "optionid": "9"
        },
        {
          "optiontext": "8",
          "optionid": "10"
        },
        {
          "optiontext": "9",
          "optionid": "11"
        },
        {
          "optiontext": "10",
          "optionid": "12"
        },
        {
          "optiontext": "&gt;10",
          "optionid": "13"
        }
      ]
    }
}}

{{< block_coursefeedback/surveyitems/base }}
    {{$layout}}2-columns{{/layout}}
    {{$answer_area_content}}
        <label for="block_coursefeedback-surveyitem-{{surveyitemid}}" class="sr-only">
            {{questiontext}}
        </label>
        <select class="custom-select" name="surveyitem-{{surveyitemid}}"
                {{#required}}required{{/required}}
                id="block_coursefeedback-surveyitem-{{surveyitemid}}">
            <option value="">{{#str}}please_select, block_coursefeedback{{/str}}</option>
            {{# options }}
                <option value="{{optionid}}">{{{optiontext}}}</option>
            {{/ options }}
        </select>
    {{/answer_area_content}}
{{/ block_coursefeedback/surveyitems/base }}
