{{!
    @template block_coursefeedback/surveyitems/emoji

    This template renders the display of an emoji question.

    Example context (json):
    {
      "type_emoji": true,
      "type": "emoji",
      "surveyitemid": 5,
      "questiontext": "<p>Was hat Ihnen an der Veranstaltung gefallen?</p>",
      "choices": [
        {
          "emoji": "😀",
          "text": "excellent",
          "value": 1
        }
      ]
    }

}}
{{< block_coursefeedback/surveyitems/base }}
    {{$answer_area_content}}
        {{#choices}}
            <input type="radio" class="block_coursefeedback-btn-check" name="surveyitem-{{surveyitemid}}"
                   id="block_coursefeedback-surveyitem-{{surveyitemid}}-{{value}}" value="{{value}}">
            <label class="btn btn-outline-primary" for="block_coursefeedback-surveyitem-{{surveyitemid}}-{{value}}">
                <span class="coursefeedback-choice-emoji">{{emoji}}</span>
                {{{text}}}
            </label>
        {{/choices}}
    {{/answer_area_content}}
{{/ block_coursefeedback/surveyitems/base }}
