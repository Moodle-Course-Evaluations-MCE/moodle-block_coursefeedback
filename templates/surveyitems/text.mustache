{{!
    @template block_coursefeedback/surveyitems/text

    This template renders the display of a text question.

    Example context (json):
    {
      "type_text": true,
      "type": "text",
      "surveyitemid": 5,
      "questiontext": "<p>Was hat Ihnen an der Veranstaltung gefallen? Was sollte beibehalten werden?<\/p>",
      "initialrows": 42,
      "maxlength": 500
    }

}}

{{< block_coursefeedback/surveyitems/base }}
    {{$answer_area_content}}
        <textarea class="form-control" rows="{{ initialrows }}" maxlength="{{ maxlength }}"></textarea>
    {{/answer_area_content}}
{{/ block_coursefeedback/surveyitems/base }}
