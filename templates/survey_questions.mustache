{{!
    @template block_coursefeedback/survey_questions

    Render a collection of questions.

    Example context (json):
    {
    }

}}

{{# questions }}
    <div class="mb-5">
        {{# type_text }}
            {{> block_coursefeedback/surveyitems/text }}
        {{/ type_text }}
        {{# type_multiplechoice }}
            {{> block_coursefeedback/surveyitems/multiplechoice }}
        {{/ type_multiplechoice }}
        {{# type_singlechoice }}
            {{> block_coursefeedback/surveyitems/singlechoice }}
        {{/ type_singlechoice }}
        {{# type_scalequestion }}
            {{> block_coursefeedback/surveyitems/scalequestion }}
        {{/ type_scalequestion }}
    </div>
{{/ questions }}
