{{#info_message}}
    {{< block_coursefeedback/info_box }}
        {{$message}}{{.}}{{/message}}
    {{/ block_coursefeedback/info_box }}
{{/info_message}}

<div class="row gx-3">
    <div class="col-lg-8 my-1">
        <div class="card h-100">
            <section class="card-body">
                <h5 class="card-title">{{#str}} survey_execution_period, block_coursefeedback {{/str}}</h5>

                {{#survey_execution_period_context}}
                    {{> block_coursefeedback/survey_execution_period }}
                {{/survey_execution_period_context}}
            </section>
        </div>
    </div>
    <div class="col-lg-4 my-1">
        <div class="card h-100">
            <section class="card-body">
                <h5 class="card-title">{{#str}} course_survey_status, block_coursefeedback {{/str}}</h5>

                <div>
                    <p>
                        <strong>{{#str}} status {{/str}}</strong>
                        <br>
                        {{localized_status}}
                    </p>
                </div>

                <div>
                    <p>
                        <strong>{{#str}} num_responses, block_coursefeedback {{/str}}</strong>
                        <br>
                        {{num_responses}}
                    </p>
                </div>

                {{#show_delete_responses}}
                    <a class="text-danger small" href="#"
                       data-modal="confirmation"
                       data-modal-title-str='["delete_survey_responses", "block_coursefeedback"]'
                       data-modal-content-str='["delete_survey_responses_confirm", "block_coursefeedback", {
                        "coursename": {{#quote}}{{course_fullname}}{{/quote}},
                        "num": {{num_responses}}
                       }]'
                       data-modal-yes-button-str='["delete", "core"]'
                       data-modal-destination="{{delete_responses_url}}">
                        {{#str}}delete_survey_responses, block_coursefeedback{{/str}}
                    </a>
                {{/show_delete_responses}}
            </section>
        </div>
    </div>
</div>
{{#show_event_table}}
    <section class="mt-4">
        <h4 class="mb-3">{{#str}} course_event_slot_table_heading, block_coursefeedback {{/str}}</h4>

        {{#show_instructions}}
            <p>{{#str}} course_settings_explanation_general, block_coursefeedback {{/str}}</p>

            <div class="card mb-3">
                <section class="card-body">
                    <h5 class="card-title">{{#str}}
                        course_settings_explanation_title, block_coursefeedback {{/str}}</h5>

                    <dl class="mb-0">
                        <dt>{{#str}} teaching_events, block_coursefeedback {{/str}}</dt>
                        <dd>{{#str}} course_settings_explanation_events, block_coursefeedback {{/str}}</dd>

                        <dt>{{#str}} slots, block_coursefeedback {{/str}}</dt>
                        <dd>{{#str}} course_settings_explanation_slots, block_coursefeedback {{/str}}</dd>

                        <dt>{{#str}} slot_users, block_coursefeedback {{/str}}</dt>
                        <dd>{{#str}} course_settings_explanation_slot_users, block_coursefeedback {{/str}}</dd>
                    </dl>
                </section>
            </div>
        {{/show_instructions}}

        {{#table_context}}
            {{> block_coursefeedback/course_event_slot_table }}
        {{/table_context}}
    </section>
{{/show_event_table}}
