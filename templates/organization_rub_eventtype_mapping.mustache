{{!
    @template block_coursefeedback/organization_default_surveypart

    This template renders the editing default surveyparts for an organization.

    Example context (json):
    {
    }

}}

<form action="{{{formurl}}}" method="post">
    <table class="table table-striped table-hover generaltable">
        <thead>
            <tr>
                <th>{{#str}}coursetype_from_campus, block_coursefeedback{{/str}}</th>
                <th>{{#str}}eventtype, block_coursefeedback{{/str}}</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        {{#mappings}}
            <tr>
                <td>
                    {{name}}
                </td>
                <td>
                    <select class="form-control form-select" name="coursetype-{{id}}">
                        <option value="">-</option>
                        {{#eventtypes}}
                            <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
                        {{/eventtypes}}
                    </select>
                </td>
                <td>
                </td>
            </tr>
        {{/mappings}}
        </tbody>
    </table>
    <input type="hidden" name="sesskey" value="{{sesskey}}">
    <input type="submit" name="submit" value="{{#str}}save{{/str}}" class="btn btn-primary">
    <a href="{{{returnurl}}}" class="btn btn-secondary">{{#str}}cancel{{/str}}</a>
</form>