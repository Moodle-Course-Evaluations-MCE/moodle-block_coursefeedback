{{!
    @template block_coursefeedback/organization_default_surveypart

    This template renders the editing default surveyparts for an organization.

    Example context (json):
    {
         "id":1,
         "name":"Vorlesung",
         "surveyparts":[
            {
               "id":1,
               "name":"Survey #1",
               "selected":true
            },
            {
               "id":2,
               "name":"Survey #2"
            }
         ]
     }
}}

<tr>
    <td>
        <input
                type="text"
                name="name-{{id}}"
                aria-label="{{#str}}eventtype, block_coursefeedback{{/str}}"
                value="{{name}}"
                class="form-control">
    </td>
    <td>
        <select class="form-control form-select" name="surveypart-{{id}}">
            <option value="">-</option>
            {{#surveyparts}}
                <option value="{{id}}" {{#selected}}selected{{/selected}}>{{name}}</option>
            {{/surveyparts}}
        </select>
    </td>
    <td>
    </td>
</tr>
